[1.272961, "o", "# random v0.1.2\r\nRandom number, string, and UUID generation\r\n\r\n## uuid\r\nGenerate a UUID (v4 random or v7 time-ordered)\r\n[read-only]\r\nParameters:\r\n  version: any — UUID version: 4 (random, default) or 7 (time-ordered)\r\n\r\n## random_string\r\nGenerate a cryptographically random string\r\n[read-only]\r\nParameters:\r\n  charset: any — Character set: 'alphanumeric' (default), 'hex', 'alpha', 'digits', 'ascii'\r\n  length: integer (required) — Length of the string\r\n\r\n## random_number\r\nGenerate a cryptographically random integer in a range\r\n[read-only]\r\nParameters:\r\n  max: any — Maximum value (inclusive, default 100)\r\n  min: any — Minimum value (inclusive, default 0)\r\n"]
